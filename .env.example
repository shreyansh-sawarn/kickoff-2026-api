# Admin UI
ADMIN_PASSWORD=changeme_admin_password

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/wc26.db

# Scraper settings
SCRAPER_ENABLED=true
POLL_INTERVAL_LIVE_SECONDS=60
POLL_INTERVAL_IDLE_SECONDS=300
POLL_INTERVAL_NIGHT_SECONDS=900
WIKIPEDIA_USER_AGENT=kickoff-2026-api/1.0 (contact@youremail.com)

# CORS (comma-separated origins allowed to call your API)
CORS_ORIGINS=https://kickoff-2026.vercel.app,http://localhost:3000

# API Key auth (Phase 3 — set to true to require API keys)
REQUIRE_API_KEY=false

# Webhook signing secret (Phase 2)
WEBHOOK_SIGNING_SECRET=

# Session secret (for admin cookie signing — use a long random string)
SESSION_SECRET=change_me_to_a_long_random_secret

# Optional: Sentry DSN for error tracking (free tier)
SENTRY_DSN=
